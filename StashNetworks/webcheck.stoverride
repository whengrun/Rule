name: 网络检测
desc: 流媒体与GPT检测
icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/AI.png
category: '网络检测'
version: 'b1'

tiles:
  - name: dual-ip-script
    interval: 600
    title: '双路 IP 检测'
    content: fasle
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/dual-ip.png
  - name: IPPure IP Info
    title: IPPure IP 信息
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com
  - name: IPPure IP Fraud Score
    title: IPPure IP 风险评分
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com
  - name: IPPure IP Native Check
    title: IPPure 原生 IP 检查
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com
  - name: ChatGPT-Web-Check
    title: ChatGPT Web
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/chatgpt.png
    collapsed: true
    url: https://chatgpt.com
  - name: ChatGPT-App-Check
    title: ChatGPT App
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/chatgpt.png
    collapsed: false
    url: https://chatgpt.com
  - name: Gemini-Check
    title: Gemini
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/gemini.png
    collapsed: fasle
    url: https://gemini.google.com/  
  - name: YouTube-Check
    title: YouTube
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/youtube.png
    collapsed: true
    url: https://www.youtube.com
  - name: Netflix-Check
    title: Netflix
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/netflix.png
    collapsed: true
    url: https://www.netflix.com
  - name: Disney-Check
    title: Disney+
    icon: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/img/disney.png
    collapsed: true
    url: https://www.disneyplus.com/

script-providers:
  IPPure IP Info:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/ippure-ip-info.js
  IPPure IP Fraud Score:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/ippure-ip-fraud-score.js
  IPPure IP Native Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/ippure-ip-native-check.js
  ChatGPT-Web-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/chatgpt-web.js
  ChatGPT-App-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/chatgpt-app.js
  Gemini-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/Gemini.js
  YouTube-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/youtube.js
  Netflix-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/netflix.js
  Disney-Check:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/Disney+.js
  dual-ip-script:
    url: https://raw.githubusercontent.com/whengrun/Rule/master/StashNetworks/script/dual-ip.js
